@article{neupane2026inversion,
  abbr={HFS 2026},
  title={The Information Dynamics of Insider Intent: How Reporting Inversions (Form 144) Mask Informational Rents in Insider Sales (Form 4)},
  author={Neupane, Krishna},
  journal={Working Paper, Under Review at 14th Helsinki Finance Summit on Investor Behavior},
  year={2026},
  url={http://krishpn.github.io},
  abstract={This study identifies a significant informational friction in the SEC Form 144 regime termed predictive decoupling. It argues that the current reporting inversion—where Form 4 precedes Form 144—violates Pareto efficiency. Utilizing an event-study framework, the machine learning audit reveals a 52.4\% opacity rate in aborted sale signals. The study documents a large-cap significance paradox and proposes a mandatory Form 144-A to restore informational symmetry.},
  note={Preprint submitted for conference review},
  selected={true}
}


@article{neupane2026strategicgap,
  abbr={JBEP},
  title={The Strategic Gap: How AI-Driven Timing and Complexity Shape Investor Trust in the Age of Digital Agents},
  author={Neupane, Krishna},
  journal={Working Paper, Under Review at Journal of Behavioral and Experimental Economics},
  year={2026},
  url={http://krishpn.github.io},
  abstract={Traditional models of market efficiency assume that equity prices incorporate information based on content alone, often neglecting the structural influence of reporting timing and cadence. This study introduces the Autonomous Disclosure Regulator, a multi-node AI framework designed to audit the intersection of disclosure complexity and filing unpredictability. Analyzing a population of 484,796 regulatory filings, the research identifies a structural Strategic Gap: a state where companies use confusing language and unpredictable timing to slow down how fast the market learns the truth by 60\%.},
  note={Preprint submitted for publication},
  selected={true}
}

@article{neupane2026estimatingcausal,
  abbr={EJoN},
  title={Estimating the Causal Impact of Disclosure Sentiment on Banking Performance Using Causal Forests},
  author={Neupane, Krishna and Sapkota, Prem and Prajapati, Ujjwal},
  journal={Working Paper, Under Review at The Economic Journal of Nepal (EJoN)},
  year={2025},
  url={http://krishpn.github.io},
  abstract={This study establishes the causal effects of financial report sentiment on bank profitability, moving beyond traditional correlational analyses. Utilizing a Causal Forest machine learning methodology and a pre-trained FinancialBERT model, the research analyzes commercial banks from the Nepal Stock Exchange (NEPSE) and Nepal Rastra Bank (NRB). The study employs SHAP analysis and Average Treatment Effect (ATE) calculations to differentiate between predictive importance and causal impact in banking performance.},
  note={Preprint submitted for publication},
  selected={false}
}

